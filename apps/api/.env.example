NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://living_cost:living_cost_dev@localhost:5432/living_cost_manager?schema=lcm
API_TEST_DATABASE_URL=postgresql://living_cost:living_cost_dev@localhost:5432/living_cost_manager?schema=lcm_test
JWT_SECRET=dev-only-change-me-jwt-secret-at-least-32-chars
CORS_ORIGIN=http://localhost:3000
API_BASE_PATH=

# 비밀번호 재설정 / 이메일 인증 링크에 쓰일 프론트엔드 base URL
APP_BASE_URL=http://localhost:3000

# 이메일 발송 설정.
# 아래 키들이 모두 미설정이면 console 폴백으로 동작합니다 — 메일이 실제로
# 발송되지 않고 서버 로그에만 링크가 찍힙니다(로컬 개발 기본값).
# 실제 발송을 켜려면 resend 또는 smtp 블록의 주석을 풀고 값을 채우세요.
# 운영(OCI)에서는 EMAIL_PROVIDER=resend + RESEND_API_KEY가 .env.oci에 주입됩니다.
#
# 주의: 이 옵션 키들은 zod optional이라 "빈 문자열"을 주입하면 검증이 실패할 수
# 있습니다. 쓰지 않을 키는 값을 비우지 말고 줄 전체를 주석으로 남겨두세요.
EMAIL_FROM=Living Cost Manager <noreply@example.com>
#
# --- Resend 사용 시 ---
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
#
# --- SMTP 사용 시 ---
# EMAIL_PROVIDER=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=apikey-or-username
# SMTP_PASS=secret

# 토큰 수명(초). 줄을 주석 처리하면 코드 기본값(access 900, refresh 7d,
# reset 1h, verify 24h)을 사용합니다.
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=604800
PASSWORD_RESET_TTL=3600
EMAIL_VERIFICATION_TTL=86400

POSTGRES_USER=living_cost
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=living_cost_manager
