{
  "name": "@living-cost-manager/api",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/app.js",
  "types": "dist/app.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "tsx tests/setup-test-db.ts && vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@living-cost-manager/shared": "workspace:*",
    "@prisma/client": "^6.19.0",
    "argon2": "^0.44.0",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "nodemailer": "^8.0.8",
    "prisma": "^6.19.3",
    "resend": "^6.12.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
