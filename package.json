{
  "name": "living-cost-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @living-cost-manager/web dev",
    "build": "pnpm --filter @living-cost-manager/web build",
    "start": "pnpm --filter @living-cost-manager/web start",
    "test": "pnpm -r test",
    "test:web": "pnpm --filter @living-cost-manager/web test",
    "test:api": "pnpm --filter @living-cost-manager/api test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0"
  },
  "devDependencies": {
    "prisma": "^6.19.0"
  },
  "packageManager": "pnpm@11.1.3"
}
