generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  name            String
  passwordHash    String
  tokenVersion    Int               @default(0)
  emailVerifiedAt DateTime?
  memberships     WorkspaceMember[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  pushSubscriptions       PushSubscription[]
  pushDeliveries          PushDelivery[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// 발송 이력 — 중복 발송 방지용. dedupeKey 는 "발송 대상 날짜"(YYYY-MM-DD,
// 묶음 발송이므로 사용자당 하루 1건). (userId, dedupeKey) 가 unique 이므로
// 배치를 같은 날 재실행해도 한 번만 발송된다.
model PushDelivery {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dedupeKey String
  sentAt    DateTime @default(now())

  @@unique([userId, dedupeKey])
  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Workspace {
  id            String                @id @default(cuid())
  name          String
  monthlyIncome Int                   @default(0)
  syncVersion   Int                   @default(0)
  members       WorkspaceMember[]
  invitations   WorkspaceInvitation[]
  categories    Category[]
  cards         PaymentCard[]
  fixedCosts    FixedCost[]
  backups       BackupSnapshot[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
}

model WorkspaceInvitation {
  id          String        @id @default(cuid())
  workspaceId String
  email       String
  role        WorkspaceInvitationRole
  status      WorkspaceInvitationStatus @default(pending)
  tokenHash   String        @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())

  @@index([email])
  @@index([workspaceId])
}

enum WorkspaceRole {
  owner
  editor
  viewer
}

enum WorkspaceInvitationRole {
  editor
  viewer
}

enum WorkspaceInvitationStatus {
  pending
  accepted
  revoked
  expired
}

model Category {
  id          String
  workspaceId String
  label       String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fixedCosts  FixedCost[] @relation("FixedCostCategory")

  @@id([workspaceId, id])
  @@unique([workspaceId, label])
}

model PaymentCard {
  id           String
  workspaceId  String
  label        String
  billingDay   Int
  isEndOfMonth Boolean @default(false)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fixedCosts  FixedCost[] @relation("FixedCostPaymentCard")

  @@id([workspaceId, id])
}

model FixedCost {
  id              String
  workspaceId     String
  name            String
  categoryId      String
  paymentMethodId String
  paymentCardId    String?
  paymentOptionKey String?
  amount          Int
  periodMonths    Float     @default(1)
  billingDay      Int
  isEndOfMonth    Boolean   @default(false)
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  category        Category  @relation("FixedCostCategory", fields: [workspaceId, categoryId], references: [workspaceId, id])
  paymentCard     PaymentCard? @relation("FixedCostPaymentCard", fields: [workspaceId, paymentCardId], references: [workspaceId, id], onDelete: NoAction)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@id([workspaceId, id])
  @@index([workspaceId, categoryId])
  @@index([workspaceId, paymentCardId])
}

model BackupSnapshot {
  id          String    @id @default(cuid())
  workspaceId String
  payload     Json
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}
